# GachaDex API — copy to .env for local dev. NEVER commit real secrets.
# Every value below has a safe default in src/config.ts; this file documents the knobs.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Comma-separated web origins allowed via CORS (your Vercel URL in prod)
WEB_ORIGINS=http://localhost:5173,http://localhost:4173

# Database: leave empty to use embedded PGlite (local dev, zero deps).
# In prod set to a managed Postgres connection string (Neon/Supabase).
DATABASE_URL=
PGLITE_DIR=./.pglite

# Auth (SIWS -> JWT). In production JWT_SECRET must be set to a strong >=32-char value.
JWT_SECRET=change-me-in-prod
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=604800
AUTH_DOMAIN=localhost

# Price oracle (server-side only; pokemontcg.io is keyless at lower rate limits).
# This single feed powers BOTH the individual card markets and the Top 100 / Top 250 indices.
POKEMONTCG_API_KEY=
ORACLE_REFRESH_MS=21600000   # 6h (the source updates ~daily)
ORACLE_PAGE_SIZE=250         # pokemontcg.io v2 caps pageSize at 250; higher is a silent no-op

# JustTCG graded (PSA-10) pricing — OPTIONAL. Set the key to make the Graded index tradeable
# (priced off a basket of the top-N cards' PSA-10 prices). Without it, Graded stays gated.
JUSTTCG_API_KEY=
JUSTTCG_BASE=https://api.justtcg.com
GRADED_CONSTITUENTS=100

# Money / safety
REAL_FUNDS=false             # HARD GATE — must stay false in this build (real custody is post-audit/legal)

# Solana network / custody RPC (ONLY used when REAL_FUNDS=true; play-money trading ignores these).
# SOLANA_RPC_URL defaults to devnet in src/config.ts — point it at your MAINNET provider for real funds.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com   # use a dedicated provider (Helius/QuickNode) in prod
USDC_MINT=                                            # mainnet USDC = EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Real money on MAINNET is hard-gated behind audit + KYC/AML + geofence (custody P4). Until then,
# REAL_FUNDS+mainnet refuses to boot unless you explicitly acknowledge it here:
ALLOW_MAINNET_FUNDS=false    # set true ONLY once those gates are met
FAUCET_DEFAULT_USD=10000     # play-USDC per faucet claim; per-account balance is capped at $1,000,000
REFERRAL_BONUS_USD=1000      # play-USDC paid to BOTH parties when a referral code is redeemed (0 disables)
MAX_REFERRALS_PAID=50        # a referrer is only paid a bonus for their first N referrals (anti-farming)

# Trading commission (basis points of notional; 10 bps = 0.10%). Default 0 = no fee.
OPEN_FEE_BPS=0               # commission to open  (0 = off)
CLOSE_FEE_BPS=0              # commission to close (0 = off)
FEE_LP_SHARE_PCT=50          # % of any commission to LPs (rest to platform fee revenue)

# Funding (skew-balancing; the heavy side pays the light side)
FUNDING_SKEW_FACTOR_BPS=30   # max per-accrual rate component
FUNDING_INTERVAL_MS=3600000  # hourly accrual

# Liquidations + circuit breakers
LIQ_FEE_BPS=100              # 1% liquidation penalty -> insurance fund
LIQUIDATION_SWEEP_MS=5000    # maintenance-margin sweep cadence
ORACLE_STALE_MS=129600000    # halt a market if no fresh oracle print in 36h

# Pool risk caps (protect the LP vault; 0 = OFF). Off by default for play-money; turn ON for real
# funds. Starting values below are from docs/liquidity-calibration.md — TUNE against your own risk
# model. Rule: ADL must be >= the open-gate (the app refuses to boot otherwise).
OI_CAP_NAV_BPS=4000          # per-side OI cap = 40% of LP NAV (so one position can't outgrow the pool)
MAX_PNL_FACTOR_BPS=6000      # open-gate: pause NEW opens once traders are up > 60% of NAV
ADL_PNL_FACTOR_BPS=8000      # auto-deleverage: force-close the biggest winners once up > 80% of NAV
