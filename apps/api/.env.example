# PokeX API — copy to .env for local dev. NEVER commit real secrets.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Comma-separated web origins allowed via CORS (Vercel URL in prod)
WEB_ORIGINS=http://localhost:5173,http://localhost:4173

# Database: leave empty to use embedded PGlite (local dev, zero deps).
# In prod set to a managed Postgres connection string (Neon/Supabase).
DATABASE_URL=
PGLITE_DIR=./.pglite

# Auth
JWT_SECRET=change-me-in-prod
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=604800
AUTH_DOMAIN=localhost

# Price source (server-side only; keyless works at lower rate limits)
POKEMONTCG_API_KEY=

# Hard gate: must stay false in the MVP. Real custody is post-audit/legal.
REAL_FUNDS=false
FAUCET_DEFAULT_USD=10000
