# GachaDex web — copy to .env for local dev. Vite only exposes VITE_*-prefixed vars to the client.

# Backend API base URL (src/lib/api.js falls back to http://localhost:4000).
VITE_API_URL=http://localhost:4000

# Solana RPC the app connects to. Defaults to the public mainnet-beta endpoint, which is heavily
# rate-limited — set this to a dedicated MAINNET provider. e.g.
#   https://mainnet.helius-rpc.com/?api-key=YOUR_KEY   (Helius)
#   https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_TOKEN/   (QuickNode)
VITE_SOLANA_RPC=
